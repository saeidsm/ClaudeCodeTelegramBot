# Sentry — read-only token with org:read, project:read, event:read
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_BASE_URL=https://sentry.io

# Optional: timezone for date parsing (default: Asia/Tehran)
NIGHTWATCH_TZ=Asia/Tehran

# Optional: enable noon run (Phase 1 reads but does not act on this)
NIGHTWATCH_TWICE_DAILY=false

# Snapshot retention
NIGHTWATCH_RETENTION_DAYS=30

# ── Phase 2B — digest delivery to the bot's IPC endpoint ──
BOT_IPC_URL=http://127.0.0.1:9091
BOT_IPC_HMAC_SECRET=                       # MUST equal the bot's BOT_NIGHTWATCH_HMAC_SECRET
NIGHTWATCH_TELEGRAM_CHAT_IDS=              # comma-separated; required (fail-loud if empty)
NIGHTWATCH_REPORT_BASE_URL=https://devops.shahrzad.ai/reports
NIGHTWATCH_SENTRY_ORG_URL=https://shahrzad-ai.sentry.io

# ── Bug 1 fix (2026-04-28) — webroot bridge ──
# Publisher mirrors each snapshot into NIGHTWATCH_WEBROOT_DIR/nightwatch-<date>/
# AFTER the IPC POST returns 202, so the "📊 Full Report" button URL resolves.
# Both vars are token-gated: the webroot lives in a 64-char hex sub-dir of
# /opt/shahrzad-devops/reports/ that Caddy serves, and the report URL is
# {NIGHTWATCH_REPORT_BASE_URL}/{NIGHTWATCH_REPORT_TOKEN}/nightwatch-<date>/.
# Leave both empty to skip bridging (a warning is logged; digest still ships).
NIGHTWATCH_WEBROOT_DIR=                     # e.g. /opt/shahrzad-devops/reports/<TOKEN>
NIGHTWATCH_REPORT_TOKEN=                    # 64-char hex; same value as the last segment of WEBROOT_DIR
