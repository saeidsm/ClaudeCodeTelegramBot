# ── Required ──
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=123456789              # Comma-separated authorized chat IDs

# ── Gemini (voice transcription + fallback) ──
GEMINI_API_KEY=your-gemini-api-key

# ── Optional: Fallback AI providers ──
OPENAI_API_KEY=                         # For GPT-4o fallback
OPENROUTER_API_KEY=                     # For OpenRouter model selection

# ── Optional: Production server (for health/logs/deploy buttons) ──
PROD_SERVER_IP=                         # e.g. 192.168.1.100
PROD_SERVER_USER=root                   # SSH user for production

# ── Optional: Paths (defaults to bot.py directory) ──
# BOT_BASE_DIR=/opt/mybot
# BOT_REPOS_DIR=/opt/mybot/repos
# BOT_REPORTS_DIR=/opt/mybot/reports
# BOT_LOGS_DIR=/opt/mybot/logs
# BOT_SCRIPTS_DIR=/opt/mybot/scripts
# BOT_UPLOADS_DIR=/opt/mybot/uploads
# BOT_PROMPTS_FILE=/opt/mybot/configs/gemini-prompts.json
# BOT_PROJECTS_FILE=/opt/mybot/configs/projects.json
# BOT_USAGE_DB=/opt/mybot/configs/usage_tracker.json

# ── Optional: Bot behavior ──
# BOT_REPORT_URL=https://your-server.com/reports
# BOT_DEFAULT_PROJECT=MyProject
# BOT_PERMANENT_PROJECTS=ProjectA,ProjectB   # Never auto-close these sessions
# BOT_MAX_SESSIONS=3
# BOT_SESSION_TIMEOUT_HOURS=72
# BOT_PAUSE_SECONDS=5

# ── Optional: Token limits ──
# BOT_HOURLY_TOKEN_LIMIT=100000
# BOT_DAILY_TOKEN_LIMIT=1000000
# BOT_WEEKLY_TOKEN_LIMIT=5000000

# ── Optional: GPT fallback model ──
# BOT_GPT_FALLBACK_MODEL=gpt-4o
